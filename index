  {id:'UKHAI-2025-0233',dt:'01 Sep 2025',sv:'Severe harm',sc:'bd-s',tp:'Diagnostic imaging AI',se:'Screening programme',rg:'North West England (anon)',ti:'Retinopathy AI graded borderline-quality image without enforcing repeat; vision loss',su:'System allowed AI grading of borderline-quality image. "No retinopathy" issued. Proliferative retinopathy found 12 months later; vision loss in one eye.',fc:['System allowed grading of borderline images','Quality flag in metadata only','Repeat protocol paper-based'],lrn:'AI diagnostic systems must enforce mandatory pre-conditions as system constraints, not advisory flags.',tg:['Diabetic retinopathy','Image quality','Screening'],out:null},
