<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UK Healthcare AI Safety Registry · v0.5</title>
<style>
:root{
  --navy:#042C53;--navy2:#0A3060;--amber:#EF9F27;
  --w:#fff;--g50:#f9fafb;--g100:#f3f4f6;--g200:#e5e7eb;--g300:#d1d5db;
  --g400:#9ca3af;--g500:#6b7280;--g600:#4b5563;--g700:#374151;--g900:#111827;
  --red50:#fef2f2;--red100:#fee2e2;--red700:#b91c1c;
  --or100:#ffedd5;--or700:#c2410c;
  --ye100:#fef9c3;--ye700:#a16207;
  --bl50:#eff6ff;--bl100:#dbeafe;--bl700:#1d4ed8;
  --gr50:#f0fdf4;--gr100:#dcfce7;--gr700:#15803d;
  --pu100:#ede9fe;--pu700:#6d28d9;
  /* Emil: strong custom curves — never use built-in easings for UI */
  --eout:cubic-bezier(0.23,1,0.32,1);   /* entering elements — starts fast */
  --eio:cubic-bezier(0.77,0,0.175,1);   /* on-screen morphing */
  --ein:cubic-bezier(0.55,0,1,0.45);    /* exit only */
  --edrawer:cubic-bezier(0.32,0.72,0,1);
  --r4:4px;--r6:6px;--r10:10px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;font-size:14px;color:var(--g900);background:var(--g50)}
#shell{display:flex;flex-direction:column;height:100vh;overflow:hidden}
#hdr{background:var(--navy);padding:11px 20px;border-bottom:3px solid var(--amber);flex-shrink:0}
#statsbar{background:var(--navy2);flex-shrink:0}
#navbarnav{background:var(--w);border-bottom:1px solid var(--g200);flex-shrink:0;overflow-x:auto}
#content{flex:1;overflow-y:auto;background:var(--g50)}

/* Header */
.hi{display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:10px}
.lb{background:var(--amber);color:var(--navy);width:34px;height:34px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;flex-shrink:0}
.ln{color:var(--w);font-size:14px;font-weight:600}
.ls{color:rgba(255,255,255,.4);font-size:11px;margin-top:1px}
.proto{background:rgba(239,159,39,.12);border:1px solid rgba(239,159,39,.35);color:var(--amber);padding:3px 9px;border-radius:20px;font-size:10px;font-weight:500;letter-spacing:.04em}

/* Stats — countup handled by JS */
.sg{display:grid;grid-template-columns:repeat(6,1fr)}
.st{padding:8px 4px;text-align:center;border-right:1px solid rgba(255,255,255,.08)}
.st:last-child{border-right:none}
.stn{font-size:17px;font-weight:600;color:var(--amber);line-height:1.1;font-variant-numeric:tabular-nums}
.stl{font-size:9px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.05em;margin-top:1px}

/* Nav — tabs are hovered often: ease not ease-out, colour only */
.ni{display:flex;min-width:max-content}
.tab{
  padding:10px 12px;font-size:12px;font-weight:400;color:var(--g500);
  background:none;border:none;border-bottom:2.5px solid transparent;
  cursor:pointer;white-space:nowrap;font-family:inherit;
  /* colour transitions: ease, not ease-out — less punchy for frequent hover */
  transition:color 140ms ease,border-color 140ms ease;
}
.tab:hover{color:var(--g900)}
/* Active press on tabs — sub-100ms, instant feeling */
.tab:active{transform:scale(0.97);transition:transform 80ms var(--eout),color 140ms ease,border-color 140ms ease}
.tab.on{color:var(--navy);font-weight:600;border-bottom-color:var(--amber)}
.adot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--red700);margin-right:4px;vertical-align:middle;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Pages — enter with opacity+translateY; nothing appears from nowhere */
.page{display:none}
.page.on{
  display:block;
  animation:pageIn 220ms var(--eout) both;
}
@keyframes pageIn{
  from{opacity:0;transform:translateY(6px)}
  to{opacity:1;transform:translateY(0)}
}
.page-inner{max-width:1060px;margin:0 auto;padding:20px}

/* Shared */
.pt{font-size:15px;font-weight:600;color:var(--g900);margin-bottom:3px}
.ps{font-size:13px;color:var(--g500);margin-bottom:16px}
.sh{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px}
.st2{font-size:14px;font-weight:600;color:var(--g900)}
.sl2{font-size:12px;color:var(--bl700);background:none;border:none;cursor:pointer;font-family:inherit;
  transition:opacity 120ms ease}
.sl2:hover{opacity:.7}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.card{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:14px;
  box-shadow:0 1px 3px rgba(0,0,0,.05)}
.ct{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:11px}

/* Alert banner */
.ab{background:#fffbeb;border:1px solid #f59e0b;border-radius:var(--r10);padding:11px 13px;display:flex;gap:9px;margin-bottom:16px}
.abt{font-size:13px;color:#92400e;line-height:1.5}
.abt strong{font-weight:600}
.alk{color:#b45309;text-decoration:underline;background:none;border:none;cursor:pointer;font-family:inherit;font-size:13px;
  transition:opacity 120ms ease}
.alk:hover{opacity:.7}

/* Quick-report bar */
.qr{background:var(--navy);border-radius:var(--r10);padding:14px 16px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.qr-label{color:rgba(255,255,255,.7);font-size:13px;font-weight:500;flex-shrink:0}
.qr-btns{display:flex;gap:7px;flex-wrap:wrap;flex:1}
/* Quick-report buttons: background ease, transform sub-100ms */
.qrb{
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);
  color:var(--w);font-size:12px;font-weight:500;padding:6px 12px;
  border-radius:var(--r6);cursor:pointer;font-family:inherit;
  transition:background 140ms ease,transform 80ms var(--eout),border-color 140ms ease;
}
.qrb:active{transform:scale(0.96)}
.qrb.danger{background:rgba(239,68,68,.2);border-color:rgba(239,68,68,.35);color:#fca5a5}
@media(hover:hover) and (pointer:fine){
  .qrb:hover{background:rgba(255,255,255,.18)}
  .qrb.danger:hover{background:rgba(239,68,68,.32)}
}
.qr-note{font-size:11px;color:rgba(255,255,255,.35);flex-basis:100%}

/* Toast — asymmetric: enter 200ms ease-out, exit 140ms ease-in */
.toast{
  position:fixed;bottom:24px;right:24px;
  background:var(--g900);color:var(--w);
  padding:11px 16px;border-radius:var(--r10);font-size:13px;
  box-shadow:0 8px 24px rgba(0,0,0,.18);z-index:999;
  opacity:0;transform:translateY(8px) scale(0.97);
  /* Enter: ease-out 200ms */
  transition:opacity 200ms var(--eout),transform 200ms var(--eout);
  pointer-events:none;
}
.toast.show{opacity:1;transform:translateY(0) scale(1)}
/* Exit handled by removing .show — browser uses same transition */
/* But we want exit faster: override via JS class */
.toast.hide{
  opacity:0;transform:translateY(4px) scale(0.98);
  transition:opacity 140ms var(--ein),transform 140ms var(--ein);
}

/* Incident cards */
.inc{
  background:var(--w);border:1px solid var(--g200);
  border-radius:var(--r10);padding:13px;margin-bottom:9px;
  box-shadow:0 1px 3px rgba(0,0,0,.05);
}
@media(hover:hover) and (pointer:fine){
  .inc{transition:box-shadow 180ms ease,border-color 180ms ease}
  .inc:hover{box-shadow:0 4px 14px rgba(0,0,0,.08);border-color:var(--g300)}
}
.im{display:flex;align-items:flex-start;justify-content:space-between;gap:7px;margin-bottom:5px}
.iid{font-family:'SF Mono','Fira Code',monospace;font-size:10px;color:var(--g400)}
.iti{font-size:13px;font-weight:500;color:var(--g900);line-height:1.4;margin-bottom:9px}
.ifoot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:5px}
.chips{display:flex;gap:4px;flex-wrap:wrap}
.chip{font-size:11px;background:var(--g100);color:var(--g500);padding:2px 6px;border-radius:var(--r4);border:1px solid var(--g200)}
.tag{font-size:11px;background:var(--bl50);color:var(--bl700);padding:2px 6px;border-radius:20px;border:1px solid var(--bl100)}
.otag{font-size:11px;background:var(--gr50);color:var(--gr700);padding:2px 6px;border-radius:20px;border:1px solid var(--gr100)}

/* Severity badges */
.badge{font-size:11px;font-weight:600;padding:2px 8px;border-radius:var(--r4);white-space:nowrap}
.bd-d,.bd-s{background:var(--red100);color:var(--red700)}
.bd-m{background:var(--or100);color:var(--or700)}
.bd-l{background:var(--ye100);color:var(--ye700)}
.bd-n{background:var(--bl100);color:var(--bl700)}
.bd-z{background:var(--gr100);color:var(--gr700)}

/* Expand button */
.xb{
  font-size:11px;color:var(--g500);background:none;
  border:1px solid var(--g200);border-radius:var(--r4);
  padding:3px 9px;cursor:pointer;font-family:inherit;
  transition:background 120ms ease,color 120ms ease,border-color 120ms ease,transform 80ms var(--eout);
}
.xb:active{transform:scale(0.96)}
@media(hover:hover) and (pointer:fine){
  .xb:hover{background:var(--g50);color:var(--g900);border-color:var(--g300)}
}

/* Detail expand: grid trick — animates to exact content height, no lag */
.det{display:grid;grid-template-rows:0fr;transition:grid-template-rows 240ms var(--eout)}
.det.on{grid-template-rows:1fr}
.det-inner{overflow:hidden}
.di{border-top:1px solid var(--g100);margin-top:9px;padding-top:11px}
.dl{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--g400);margin-bottom:4px}
.db{font-size:12px;color:var(--g600);line-height:1.65;margin-bottom:10px}
.db ul{padding-left:15px}.db li{margin-bottom:2px}
.learn{background:var(--gr50);border:1px solid var(--gr100);border-radius:var(--r6);padding:10px 12px;margin-bottom:10px}
.learn .dl{color:var(--gr700)}.learn .db{color:var(--gr700);margin-bottom:0}
.outbox{background:var(--pu100);border:1px solid #c4b5fd;border-radius:var(--r6);padding:9px 12px;margin-top:10px}
.outbox .dl{color:var(--pu700)}.outbox .db{color:var(--pu700);margin-bottom:0}

/* Filter */
.fr{display:flex;gap:7px;margin-bottom:11px;flex-wrap:wrap}
.fr input,.fr select{
  font-size:12px;font-family:inherit;
  border:1px solid var(--g200);border-radius:var(--r6);
  padding:6px 9px;background:var(--w);outline:none;
  transition:border-color 150ms ease,box-shadow 150ms ease;
}
.fr input{flex:1;min-width:140px}
.fr select{min-width:140px}
.fr input:focus,.fr select:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(4,44,83,.08)}
.rc2{font-size:12px;color:var(--g400);margin-bottom:9px}

/* Charts */
.bw{display:flex;gap:3px;align-items:flex-end;height:100px;padding-bottom:18px;position:relative}
.bax{position:absolute;bottom:18px;left:0;right:0;height:1px;background:var(--g200)}
.bc{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;position:relative}
.bf{
  width:100%;background:var(--navy);border-radius:2px 2px 0 0;min-height:2px;
  opacity:.8;transition:opacity 140ms ease,background 140ms ease;
  transform-origin:bottom;
  animation:barGrow 400ms var(--eout) both;
}
@keyframes barGrow{from{transform:scaleY(0)}to{transform:scaleY(1)}}
@media(hover:hover) and (pointer:fine){.bf:hover{opacity:1;background:var(--amber);cursor:default}}
.bl2{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--g400);white-space:nowrap}
.hbr{display:flex;flex-direction:column;gap:8px}
.hbl{font-size:11px;color:var(--g600);margin-bottom:2px;line-height:1.2}
.hbt{display:flex;align-items:center;gap:7px}
.hbg{flex:1;background:var(--g100);border-radius:2px;height:9px;overflow:hidden}
.hbf{height:100%;background:var(--navy);border-radius:2px;opacity:.8;animation:hbarGrow 500ms var(--eout) both}
@keyframes hbarGrow{from{width:0!important}to{}}
.hbv{font-size:11px;color:var(--g400);min-width:24px;text-align:right}
.srow{display:flex;align-items:center;gap:7px;margin-bottom:6px}
.sdot{width:10px;height:10px;border-radius:50%;flex-shrink:0;border:1px solid var(--g200)}
.slbl{font-size:11px;color:var(--g600);flex:1}
.sbg{flex:2;background:var(--g100);border-radius:2px;height:9px;overflow:hidden}
.sf2{height:100%;border-radius:2px;animation:hbarGrow 500ms var(--eout) both}
.sval{font-size:11px;color:var(--g400);min-width:26px;text-align:right}

/* Underreporting */
.urcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:14px;margin-bottom:9px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.urname{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:2px}
.ursub{font-size:11px;color:var(--g500);margin-bottom:8px}
.urtrack{display:flex;height:14px;border-radius:var(--r4);overflow:hidden;margin-bottom:6px;background:var(--g100)}
.urfill{height:100%;background:var(--red700);opacity:.65;transition:width 600ms var(--eout)}
.urstat{display:flex;gap:14px;flex-wrap:wrap}
.ursi{font-size:11px;color:var(--g500)}
.ursi strong{color:var(--g900);font-weight:600}
.urwarn{font-size:11px;color:var(--red700);margin-top:6px;font-weight:500}

/* Metric */
.mc{background:var(--g100);border-radius:var(--r6);padding:11px 13px;text-align:center}
.mn{font-size:21px;font-weight:700;color:var(--g900);line-height:1;font-variant-numeric:tabular-nums}
.mln{font-size:11px;color:var(--g500);margin-top:3px}

/* Products */
.pcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:13px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
@media(hover:hover) and (pointer:fine){.pcard{transition:box-shadow 160ms ease,border-color 160ms ease}.pcard:hover{box-shadow:0 4px 12px rgba(0,0,0,.07);border-color:var(--g300)}}
.pname{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:5px}
.pnum{font-size:21px;font-weight:700;color:var(--navy);line-height:1;text-align:right;flex-shrink:0}
.pnl{font-size:10px;color:var(--g400);margin-top:2px}
.prow{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:6px;align-items:center}
.s-n{background:var(--or100);color:var(--or700);font-size:11px;font-weight:600;padding:2px 7px;border-radius:var(--r4)}
.s-m{background:var(--bl100);color:var(--bl700);font-size:11px;font-weight:600;padding:2px 7px;border-radius:var(--r4)}
.s-r{background:var(--red100);color:var(--red700);font-size:11px;font-weight:600;padding:2px 7px;border-radius:var(--r4)}
.mhra-ok{background:var(--gr50);color:var(--gr700);font-size:11px;font-weight:500;padding:2px 7px;border-radius:var(--r4);border:1px solid var(--gr100)}
.mhra-w{background:var(--red50);color:var(--red700);font-size:11px;font-weight:500;padding:2px 7px;border-radius:var(--r4);border:1px solid var(--red100)}

/* Alerts */
.acard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:15px;margin-bottom:11px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.acard.aa{border-color:#f59e0b;border-width:1.5px}
.ahead{display:flex;align-items:flex-start;justify-content:space-between;gap:7px;margin-bottom:7px}
.aid{font-family:'SF Mono',monospace;font-size:10px;color:var(--g400)}
.apill{background:#fffbeb;border:1px solid #f59e0b;color:#b45309;font-size:11px;font-weight:600;padding:1px 7px;border-radius:20px;margin-left:7px;animation:pulse 2s infinite}
.atitle{font-size:14px;font-weight:600;color:var(--g900);margin-bottom:7px}
.asum{font-size:12px;color:var(--g600);line-height:1.6;margin-bottom:9px}
.actbox{background:var(--g50);border:1px solid var(--g200);border-radius:var(--r6);padding:9px 11px;margin-bottom:9px}
.actt{font-size:12px;color:var(--g700);line-height:1.5}
.afoot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:5px}
.dlt{font-size:11px;color:var(--g500)}
.rb{font-size:11px;background:var(--g100);color:var(--g600);padding:2px 7px;border-radius:var(--r4);border:1px solid var(--g200);cursor:pointer;font-family:inherit;transition:background 120ms ease}
.rb:hover{background:var(--g200)}
.ah-h{background:var(--red100);color:var(--red700)}
.ah-m{background:var(--or100);color:var(--or700)}
.ah-l{background:var(--gr100);color:var(--gr700)}

/* Trust directory */
.tcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:13px;margin-bottom:8px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.tname{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:3px}
.tsub{font-size:11px;color:var(--g500);margin-bottom:6px}
.tly{background:var(--gr50);border:1px solid var(--gr100);color:var(--gr700);font-size:11px;font-weight:600;padding:2px 8px;border-radius:var(--r4)}
.tln{background:var(--red50);border:1px solid var(--red100);color:var(--red700);font-size:11px;font-weight:600;padding:2px 8px;border-radius:var(--r4)}
.tlp{background:var(--ye100);border:1px solid #fde68a;color:var(--ye700);font-size:11px;font-weight:600;padding:2px 8px;border-radius:var(--r4)}
.trn{font-size:19px;font-weight:700;color:var(--navy);line-height:1;text-align:right}
.trl{font-size:10px;color:var(--g400);margin-top:1px}

/* Stagger — for lists entering with the page */
.stag-list > *{
  opacity:0;transform:translateY(5px);
  animation:itemIn 260ms var(--eout) forwards;
}
.stag-list > *:nth-child(1){animation-delay:30ms}
.stag-list > *:nth-child(2){animation-delay:70ms}
.stag-list > *:nth-child(3){animation-delay:110ms}
.stag-list > *:nth-child(4){animation-delay:150ms}
.stag-list > *:nth-child(5){animation-delay:190ms}
.stag-list > *:nth-child(6){animation-delay:230ms}
.stag-list > *:nth-child(n+7){animation-delay:260ms}
@keyframes itemIn{to{opacity:1;transform:translateY(0)}}

/* Form */
.fw{max-width:540px}
.fg{margin-bottom:11px}
.fg label{display:block;font-size:12px;font-weight:600;color:var(--g700);margin-bottom:3px}
.fg input,.fg select,.fg textarea{width:100%;font-size:12px;font-family:inherit;border:1px solid var(--g200);border-radius:var(--r6);padding:6px 9px;background:var(--w);outline:none;transition:border-color 150ms ease,box-shadow 150ms ease}
.fg textarea{min-height:65px;resize:vertical}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(4,44,83,.08)}
.fdisc{font-size:11px;color:var(--g500);border:1px solid var(--g200);border-radius:var(--r6);padding:9px 11px;margin-bottom:12px;background:var(--g50);line-height:1.6}
.ibox{background:var(--bl50);border:1px solid var(--bl100);border-radius:var(--r6);padding:9px 11px;font-size:12px;color:var(--bl700);margin-bottom:12px}

/* Primary button — press is sub-100ms, feel immediate */
.sbtn{
  background:var(--navy);color:var(--w);
  padding:8px 20px;border-radius:var(--r6);
  border:none;font-size:13px;font-weight:600;
  cursor:pointer;font-family:inherit;
  transition:background 150ms ease,transform 80ms var(--eout);
}
.sbtn:active{transform:scale(0.97)}
@media(hover:hover) and (pointer:fine){.sbtn:hover{background:#063568}}

/* Submit confirm */
.confirm{display:none;text-align:center;padding:44px 16px}
.confirm.on{display:block;animation:pageIn 250ms var(--eout)}
.cico{width:50px;height:50px;background:var(--gr100);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:22px;color:var(--gr700)}
.ctit{font-size:16px;font-weight:700;color:var(--g900);margin-bottom:5px}
.cref{font-size:13px;color:var(--g600);margin-bottom:5px}
.cref span{font-family:'SF Mono',monospace;font-weight:600;color:var(--g900)}
.cbod{font-size:13px;color:var(--g500);max-width:340px;margin:0 auto 18px;line-height:1.65}

/* Gov */
.gcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r10);padding:13px 15px;margin-bottom:7px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.gtit{font-size:13px;font-weight:600;color:var(--g900);margin-bottom:4px;display:flex;align-items:center;gap:7px}
.gico{width:22px;height:22px;background:var(--navy);color:var(--w);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}
.gbod{font-size:12px;color:var(--g600);line-height:1.7}
.gfoot{font-size:11px;color:var(--g400);border-top:1px solid var(--g100);padding-top:11px;margin-top:3px;line-height:1.7}

.footer{background:var(--navy);padding:9px 20px;text-align:center;flex-shrink:0}
.footer p{font-size:11px;color:rgba(255,255,255,.3)}

@media(max-width:600px){.g2{grid-template-columns:1fr}.sg{grid-template-columns:repeat(3,1fr)}.st:nth-child(5),.st:nth-child(6){display:none}}
@media(prefers-reduced-motion:reduce){
  *{transition:none!important;animation:none!important}
  .page.on{animation:none}
  .bf,.hbf,.sf2{animation:none}
}
</style>
