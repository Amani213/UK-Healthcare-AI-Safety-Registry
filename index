<body>
<div id="shell">

<div id="hdr">
  <div class="hi">
    <div class="logo">
      <div class="lb">UK</div>
      <div><div class="ln">UK Healthcare AI Safety Registry</div><div class="ls">Risks &middot; near misses &middot; reported harms</div></div>
    </div>
    <span class="proto">Prototype v0.5</span>
  </div>
</div>

<div id="statsbar">
  <div class="sg">
    <div class="st"><div class="stn" id="s-total">0</div><div class="stl">Total reports</div></div>
    <div class="st"><div class="stn" id="s-near">0</div><div class="stl">Near misses</div></div>
    <div class="st"><div class="stn" id="s-harms">0</div><div class="stl">Harms</div></div>
    <div class="st"><div class="stn" id="s-alerts">0</div><div class="stl">Alerts issued</div></div>
    <div class="st"><div class="stn" id="s-trusts">0</div><div class="stl">Trusts reporting</div></div>
    <div class="st"><div class="stn" style="color:#f87171" id="s-rate">0%</div><div class="stl">Report rate vs deployments</div></div>
  </div>
</div>

<div id="navbarnav">
  <div class="ni">
    <button type="button" class="tab on" onclick="T('dashboard')">&#9700; Dashboard</button>
    <button type="button" class="tab" onclick="T('browse')">&#9782; Browse</button>
    <button type="button" class="tab" onclick="T('products')">&#9670; Products</button>
    <button type="button" class="tab" onclick="T('alerts')"><span class="adot"></span>Safety alerts</button>
    <button type="button" class="tab" onclick="T('analytics')">&#9636; Analytics</button>
    <button type="button" class="tab" onclick="T('trusts')">&#9872; Trust leads</button>
    <button type="button" class="tab" onclick="T('submit')">+ Submit</button>
    <button type="button" class="tab" onclick="T('governance')">&#9672; Governance</button>
  </div>
</div>

<div id="content">

<!-- DASHBOARD -->
<div id="p-dashboard" class="page on">
<div class="page-inner">
  <div class="ab">
    <span style="color:#d97706;font-size:15px;flex-shrink:0;margin-top:1px">&#9888;</span>
    <div class="abt"><strong>Active &mdash; ALERT-2026-003 &middot; 15 May 2026.</strong> All trusts using AI risk stratification in mental health must complete an equity audit by 30 Jun 2026. <button type="button" class="alk" onclick="T('alerts')">View full alert &rarr;</button></div>
  </div>
  <div class="qr">
    <span class="qr-label">&#9889; Quick report</span>
    <div class="qr-btns">
      <button type="button" class="qrb danger" onclick="QR('Near miss')">Near miss</button>
      <button type="button" class="qrb danger" onclick="QR('Low harm')">Low harm</button>
      <button type="button" class="qrb danger" onclick="QR('Moderate harm')">Moderate harm</button>
      <button type="button" class="qrb danger" onclick="QR('Severe harm')">Severe harm</button>
      <button type="button" class="qrb" onclick="QR('No harm — risk identified')">Risk identified (no harm)</button>
    </div>
    <span class="qr-note">One tap to open a minimal report. Full details optional &mdash; designed for the end of a busy surgery.</span>
  </div>
  <div class="g2">
    <div class="card"><div class="ct">Monthly reports submitted</div><div class="bw" id="ch-trend"><div class="bax"></div></div></div>
    <div class="card"><div class="ct">Reports by AI type</div><div class="hbr" id="ch-type"></div></div>
  </div>
  <div class="sh"><div class="st2">Recent incidents</div><button type="button" class="sl2" onclick="T('browse')">View all 12 &rarr;</button></div>
  <div id="d-inc" class="stag-list"></div>
</div></div>

<!-- BROWSE -->
<div id="p-browse" class="page"><div class="page-inner">
  <div class="pt">Incident database</div>
  <div class="ps">All reports, anonymised before publication. Incidents with linked outcomes shown in green.</div>
  <div class="fr">
    <input id="si" placeholder="Search title or tags&hellip;" oninput="FI()">
    <select id="sv2" onchange="FI()"><option value="">All severities</option><option>Death</option><option>Severe harm</option><option>Moderate harm</option><option>Low harm</option><option>Near miss</option><option>No harm</option></select>
    <select id="st3" onchange="FI()"><option value="">All AI types</option><option>Clinical decision support</option><option>NLP / ambient scribe</option><option>Risk stratification</option><option>Diagnostic imaging AI</option><option>Mental health / wellbeing app</option><option>Virtual ward / remote monitoring</option><option>Prescribing / EPMA</option></select>
  </div>
  <div class="rc2" id="bco">12 incidents</div>
  <div id="b-inc" class="stag-list"></div>
</div></div>

<!-- PRODUCTS -->
<div id="p-products" class="page"><div class="page-inner">
  <div class="pt">Product directory</div>
  <div class="ps">AI products with linked reports. MHRA registration status shown. Use before procurement or when authoring clinical safety cases.</div>
  <div class="fr">
    <input id="pi" placeholder="Search product or manufacturer&hellip;" oninput="FP()">
    <select id="pt2" onchange="FP()"><option value="">All types</option><option>Clinical decision support</option><option>NLP / ambient scribe</option><option>Risk stratification</option><option>Diagnostic imaging AI</option><option>Mental health / wellbeing app</option><option>Virtual ward / remote monitoring</option><option>Prescribing / EPMA</option></select>
  </div>
  <div class="rc2" id="pco">10 products</div>
  <div id="p-list" class="stag-list"></div>
  <div style="background:#fffbeb;border:1px solid #f59e0b;border-radius:var(--r6);padding:10px 12px;font-size:12px;color:#92400e;margin-top:4px">&#9888; MHRA registration status cross-referenced at last registry update. Inspired by HSJ's finding that only 3 of 23 registered AVT vendors were searchable on MHRA's site prior to May 2026.</div>
</div></div>

<!-- ALERTS -->
<div id="p-alerts" class="page"><div class="page-inner">
  <div class="pt">National safety alerts</div>
  <div class="ps">Issued where incident patterns indicate a systemic risk requiring action across NHS trusts.</div>
  <div id="al-list" class="stag-list"></div>
</div></div>

<!-- ANALYTICS -->
<div id="p-analytics" class="page"><div class="page-inner">
  <div class="sh"><div class="st2">Registry analytics</div><span style="font-size:12px;color:var(--g400)">356 reports &middot; Jan 2025 &ndash; May 2026</span></div>
  <div class="g2">
    <div class="card"><div class="ct">Severity distribution</div><div id="ch-sev"></div></div>
    <div class="card"><div class="ct">Reports by care setting</div><div class="hbr" id="ch-set"></div></div>
  </div>
  <div class="g2" style="margin-bottom:12px">
    <div class="card"><div class="ct">Top contributing factors</div><div class="hbr" id="ch-fac"></div></div>
    <div class="card"><div class="ct">Quarterly volume</div><div class="bw" id="ch-qtr"><div class="bax"></div></div></div>
  </div>
  <div class="sh" style="margin-top:4px"><div class="st2">&#9888; Underreporting signal</div><span style="font-size:12px;color:var(--g400)">Deployment volume vs report rate by category</span></div>
  <p style="font-size:12px;color:var(--g600);margin-bottom:12px;line-height:1.6">Five Yellow Card reports across 15M+ ambient voice tool consultations is not a safety record &mdash; it is a measurement failure. Where the bar is very short relative to deployment volume, the signal is likely absent, not the harm.</p>
  <div id="ur-list" class="stag-list"></div>
  <div class="g3" style="margin-top:14px">
    <div class="mc"><div class="mn">73%</div><div class="mln">Near miss or no harm</div></div>
    <div class="mc"><div class="mn">26%</div><div class="mln">Reported by clinicians</div></div>
    <div class="mc"><div class="mn">14</div><div class="mln">Days avg. to publication</div></div>
  </div>
</div></div>

<!-- TRUST LEADS -->
<div id="p-trusts" class="page"><div class="page-inner">
  <div class="pt">Trust AI safety lead directory</div>
  <div class="ps">Named accountability for closing the loop between frontline observation and regulatory submission. Trusts without a named AI safety lead are flagged.</div>
  <div class="fr">
    <input id="ti2" placeholder="Search trust&hellip;" oninput="FT()">
    <select id="tl2" onchange="FT()"><option value="">All statuses</option><option value="yes">Named lead confirmed</option><option value="part">In progress</option><option value="no">No named lead</option></select>
  </div>
  <div class="rc2" id="tco">12 trusts</div>
  <div id="t-list" class="stag-list"></div>
  <div style="font-size:11px;color:var(--g400);border-top:1px solid var(--g200);padding-top:10px;margin-top:4px;line-height:1.6">Directory populated from voluntary trust self-declaration and ICB returns. Proposed as a contractual requirement in registry governance framework v0.5.</div>
</div></div>

<!-- SUBMIT -->
<div id="p-submit" class="page"><div class="page-inner">
  <div id="sf" class="fw">
    <div class="pt">Submit an incident report</div>
    <div class="ps">Open to NHS clinicians, digital leads, patient safety officers, patients and carers. Minimal report accepted &mdash; full details optional.</div>
    <div class="ibox">&#9432; Prototype only. In a live service submissions would be encrypted and reviewed by the clinical safety panel before publication.</div>
    <div style="background:var(--navy);border-radius:var(--r6);padding:11px 13px;margin-bottom:14px">
      <div style="color:rgba(255,255,255,.7);font-size:12px;font-weight:500;margin-bottom:8px">&#9889; Minimal report &mdash; two fields required</div>
      <div class="fg" style="margin-bottom:7px"><label style="color:rgba(255,255,255,.6)">AI system / product name *</label><input id="fp" placeholder="e.g. ambient scribe, diagnostic AI, triage tool"></div>
      <div class="fg" style="margin-bottom:7px"><label style="color:rgba(255,255,255,.6)">Severity *</label><select id="fsv3"><option>Select&hellip;</option><option>Death</option><option>Severe harm</option><option>Moderate harm</option><option>Low harm</option><option>Near miss</option><option>No harm (risk identified)</option></select></div>
      <button type="button" class="sbtn" style="width:100%;margin-top:4px" onclick="SUB()">Submit minimal report</button>
    </div>
    <details style="margin-bottom:14px">
      <summary style="font-size:12px;font-weight:600;color:var(--g700);cursor:pointer;padding:8px 0">+ Add full details (optional but valuable)</summary>
      <div style="padding-top:10px">
        <div class="fg"><label>Manufacturer / developer</label><input></div>
        <div class="fg"><label>AI system type</label><select><option>Select&hellip;</option><option>Clinical decision support</option><option>Diagnostic imaging AI</option><option>NLP / ambient scribe</option><option>Risk stratification</option><option>Mental health / wellbeing app</option><option>Virtual ward / remote monitoring</option><option>Prescribing / EPMA</option><option>Triage AI</option><option>Other</option></select></div>
        <div class="fg"><label>Care setting</label><select><option>Select&hellip;</option><option>Primary care</option><option>Secondary care &mdash; acute</option><option>Community mental health</option><option>Emergency department</option><option>Screening programme</option><option>Other</option></select></div>
        <div class="fg"><label>Incident description</label><textarea placeholder="What happened? No patient or staff names."></textarea></div>
        <div class="fg"><label>Contributing factors</label><textarea style="min-height:52px" placeholder="e.g. data quality, workflow design, training gaps, inadequate oversight"></textarea></div>
        <div class="fg"><label>Key learning</label><textarea style="min-height:52px" placeholder="What should other trusts know?"></textarea></div>
        <div class="fg"><label>Your role</label><input placeholder="e.g. clinical safety officer, ward nurse, patient / carer"></div>
        <div class="fdisc">By submitting you confirm all patient-identifiable information has been removed and this report is made in good faith.</div>
        <button type="button" class="sbtn" onclick="SUB()">Submit full report</button>
      </div>
    </details>
  </div>
  <div class="confirm" id="sc">
    <div class="cico">&#10003;</div>
    <div class="ctit">Report submitted</div>
    <div class="cref">Reference: <span id="rn"></span></div>
    <div class="cbod">Your report will be reviewed by the clinical safety panel within 5 working days. You will be updated when it is published &mdash; closing the loop on what happened next.</div>
    <button type="button" class="sbtn" onclick="RST()">Submit another</button>
  </div>
</div></div>

<!-- GOVERNANCE -->
<div id="p-governance" class="page"><div class="page-inner">
  <div class="pt">Governance &amp; methodology</div>
  <div class="ps">This registry complements &mdash; not replaces &mdash; LFPSE, MHRA Yellow Card, and trust-level incident reporting.</div>
  <div id="g-list" class="stag-list"></div>
  <div class="gfoot">Concept design: May 2026. Improved following analysis of: Luke Kellaway (HSJ) on AVT underreporting &middot; Yash Morje on distributed failure pathways &middot; Paul Brady on FMEA application to AI safety. Informed by: DCB0129/0160 &middot; LFPSE taxonomy &middot; MHRA Yellow Card AI pathway &middot; AHRQ AI in Healthcare Safety Program (USA) &middot; UNESCO Recommendation on the Ethics of AI (2021) &middot; EU AI Act Annex III &middot; UK National Commission on the Regulation of AI in Healthcare (2025&ndash;26).</div>
</div></div>

</div>
<div class="footer"><p>UK Healthcare AI Safety Registry &middot; Concept prototype v0.5 &middot; Not a live service &middot; May 2026 &middot; Designed by Sarah Amani</p></div>
</div>

<div class="toast" id="toast"></div>

<script>
var TABS=['dashboard','browse','products','alerts','analytics','trusts','submit','governance'];
function T(n){
  TABS.forEach(function(p){var el=document.getElementById('p-'+p);if(el)el.className=p===n?'page on':'page';});
  document.querySelectorAll('.tab').forEach(function(b,i){
    b.className=TABS[i]===n?'tab on':'tab';
    if(TABS[i]==='alerts')b.innerHTML='<span class="adot"></span>Safety alerts';
  });
}
function QR(sev){
  T('submit');
  var el=document.getElementById('fsv3');
  for(var i=0;i<el.options.length;i++){if(el.options[i].text===sev){el.selectedIndex=i;break;}}
  document.getElementById('fp').focus();
}
var _toastTimer;
function showToast(msg){
  var t=document.getElementById('toast');
  clearTimeout(_toastTimer);
  t.className='toast';t.textContent=msg;
  requestAnimationFrame(function(){requestAnimationFrame(function(){t.classList.add('show');});});
  _toastTimer=setTimeout(function(){
    t.classList.remove('show');t.classList.add('hide');
    setTimeout(function(){t.className='toast';},160);
  },3200);
}

// Countup animation for stats — perceived performance trick
function countUp(el,target,suffix,dur){
  var start=0,step=target/((dur||600)/16);
  var id=setInterval(function(){
    start+=step;if(start>=target){start=target;clearInterval(id);}
    el.textContent=Math.floor(start)+(suffix||'');
  },16);
}
window.addEventListener('DOMContentLoaded',function(){
  setTimeout(function(){
    countUp(document.getElementById('s-total'),356,'',700);
    countUp(document.getElementById('s-near'),163,'',600);
    countUp(document.getElementById('s-harms'),94,'',500);
    countUp(document.getElementById('s-alerts'),5,'',300);
    countUp(document.getElementById('s-trusts'),41,'',400);
    // rate: count to 0.002
    var rEl=document.getElementById('s-rate'),r=0,rStep=0.002/40;
    var rId=setInterval(function(){r+=rStep;if(r>=0.002){r=0.002;clearInterval(rId);}rEl.textContent=r.toFixed(3)+'%';},16);
  },200);
});

