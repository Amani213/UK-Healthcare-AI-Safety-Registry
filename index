function IC(inc){
  return '<div class="inc" data-ti="'+inc.ti.toLowerCase()+'" data-sv="'+inc.sv+'" data-tp="'+inc.tp+'" data-tg="'+inc.tg.join(' ').toLowerCase()+'">'
    +'<div class="im"><span class="iid">'+inc.id+' &middot; '+inc.dt+'</span><span class="badge '+inc.sc+'">'+inc.sv+'</span></div>'
    +'<div class="iti">'+inc.ti+'</div>'
    +'<div class="ifoot"><div class="chips"><span class="chip">'+inc.tp+'</span><span class="chip">'+inc.se+'</span><span class="chip">'+inc.rg+'</span>'
    +inc.tg.map(function(t){return '<span class="tag">'+t+'</span>';}).join('')
    +(inc.out?'<span class="otag">&#10003; Outcome published</span>':'')
    +'</div><button type="button" class="xb" id="xb-'+inc.id+'" onclick="XD(\''+inc.id+'\')">View detail</button></div>'
    +'<div class="det" id="dt-'+inc.id+'"><div class="det-inner"><div class="di">'
    +'<div class="dl">Summary</div><div class="db">'+inc.su+'</div>'
    +'<div class="dl">Contributing factors</div><div class="db"><ul>'+inc.fc.map(function(f){return '<li>'+f+'</li>';}).join('')+'</ul></div>'
    +'<div class="learn"><div class="dl" style="color:var(--gr700)">&#9675; Key learning</div><div class="db" style="color:var(--gr700);margin-bottom:0">'+inc.lrn+'</div></div>'
    +(inc.out?'<div class="outbox"><div class="dl" style="color:var(--pu700)">&#9654; What happened next</div><div class="db" style="color:var(--pu700);margin-bottom:0">'+inc.out+'</div></div>':'')
    +'</div></div></div></div>';
}

function XD(id){
  var d=document.getElementById('dt-'+id),b=document.getElementById('xb-'+id);
  d.classList.toggle('on');
  b.textContent=d.classList.contains('on')?'Hide detail':'View detail';
}

function FI(){
  var s=document.getElementById('si').value.toLowerCase(),sv=document.getElementById('sv2').value,tp=document.getElementById('st3').value;
  var n=0;
  document.querySelectorAll('#b-inc .inc').forEach(function(c){
    var ok=(!s||(c.dataset.ti.indexOf(s)>=0||c.dataset.tg.indexOf(s)>=0))&&(!sv||c.dataset.sv===sv)&&(!tp||c.dataset.tp===tp);
    c.style.display=ok?'block':'none';if(ok)n++;
  });
  document.getElementById('bco').textContent=n+' incident'+(n!==1?'s':'');
}
function FP(){
  var s=document.getElementById('pi').value.toLowerCase(),tp=document.getElementById('pt2').value;
  var n=0;
  document.querySelectorAll('#p-list .pcard').forEach(function(c){
    var ok=(!s||(c.dataset.n.indexOf(s)>=0||c.dataset.mf.indexOf(s)>=0))&&(!tp||c.dataset.tp===tp);
    c.style.display=ok?'flex':'none';if(ok)n++;
  });
  document.getElementById('pco').textContent=n+' product'+(n!==1?'s':'');
}
function FT(){
  var s=document.getElementById('ti2').value.toLowerCase(),ld=document.getElementById('tl2').value;
  var n=0;
  document.querySelectorAll('#t-list .tcard').forEach(function(c){
    var ok=(!s||c.dataset.n.indexOf(s)>=0)&&(!ld||c.dataset.lead===ld);
    c.style.display=ok?'flex':'none';if(ok)n++;
  });
  document.getElementById('tco').textContent=n+' trust'+(n!==1?'s':'');
