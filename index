function VI(id){
  T('browse');
  setTimeout(function(){
    var e=document.getElementById('dt-'+id),b=document.getElementById('xb-'+id);
    if(e&&!e.classList.contains('on')){e.classList.add('on');if(b)b.textContent='Hide detail';}
    if(e)e.closest('.inc').scrollIntoView({behavior:'smooth',block:'center'});
  },100);
}
function SUB(){
  var p=document.getElementById('fp').value.trim(),sv=document.getElementById('fsv3').value;
  if(!p||sv==='Select…'||!sv){alert('Please complete the AI system name and severity.');return;}
  document.getElementById('rn').textContent='UKHAI-2026-'+String(Math.floor(Math.random()*900)+100).padStart(4,'0');
  document.getElementById('sf').style.display='none';
  document.getElementById('sc').className='confirm on';
}
function RST(){
  document.getElementById('fp').value='';document.getElementById('fsv3').selectedIndex=0;
  document.getElementById('sf').style.display='block';document.getElementById('sc').className='confirm';
}

function bChart(id,data,mx){
  var el=document.getElementById(id);if(!el)return;
  data.forEach(function(d,i){
    var col=document.createElement('div');col.className='bc';
    var fill=document.createElement('div');fill.className='bf';
    fill.style.height=Math.round(d.v/mx*100)+'%';
    fill.style.animationDelay=(i*30)+'ms';
    fill.title=d.l+': '+d.v;
    var lbl=document.createElement('span');lbl.className='bl2';lbl.textContent=d.l;
    col.appendChild(fill);col.appendChild(lbl);el.appendChild(col);
  });
}
function hChart(id,data,mx){
  var el=document.getElementById(id);if(!el)return;
  el.innerHTML=data.map(function(d,i){
    return '<div><div class="hbl">'+d.l+'</div><div class="hbt"><div class="hbg"><div class="hbf" style="width:'+Math.round(d.v/mx*100)+'%;animation-delay:'+(i*40)+'ms"></div></div><span class="hbv">'+d.v+'</span></div></div>';
  }).join('');
}

