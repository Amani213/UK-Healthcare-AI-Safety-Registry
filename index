  {id:'UKHAI-2025-0134',dt:'02 Jun 2025',sv:'Low harm',sc:'bd-l',tp:'NLP / ambient scribe',se:'Primary care',rg:'Midlands (anon)',ti:'Ambient scribe misattributed resolved allergy status; incorrect prescribing record',su:'Temporal context error conflated allergy history across consultations. Penicillin allergy documented as resolved. Caught at dispensing pharmacy.',fc:['Temporal context errors in NLP output','No mandatory verification of AI-generated allergy fields','Pharmacy safety netting effective'],lrn:'AI-generated allergy fields require mandatory clinician verification before record commit.',tg:['Medication safety','NLP error','Allergy record'],out:'Led to ALERT-2026-001. Manufacturer ScribeAI NHS Edition issued mandatory update adding active allergy verification. Deployed across 14 trusts.'},
